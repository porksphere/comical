# Stage 1: build the static assets
FROM oven/bun:1 AS builder

WORKDIR /app

COPY package.json bun.lock ./
COPY packages/ packages/
COPY bridges/ bridges/
RUN bun install --frozen-lockfile

COPY demo/app.ts demo/index.html demo/build.ts demo/

RUN bun run demo/build.ts

# Stage 2: serve the pre-built assets
FROM oven/bun:1

WORKDIR /app

COPY --from=builder /app/demo/.out demo/.out
COPY demo/serve.ts demo/

ENV PORT=3300
ENV NODE_ENV=production
EXPOSE 3300

CMD ["bun", "run", "demo/serve.ts"]
