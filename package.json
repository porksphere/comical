{
  "name": "comical",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Configurable, content-neutral bridge runtime for serialized content",
  "workspaces": [
    "packages/*",
    "bridges/*"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "cli": "bun run packages/cli/src/index.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
